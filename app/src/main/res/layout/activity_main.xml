<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#2d2d2d">

        <Button
            android:id="@+id/btn_vpn_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="START RADAR"
            android:textColor="#ffffff" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tap START to activate"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingHorizontal="8dp" />

        <TextView
            android:id="@+id/zone_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zone: --"
            android:textColor="#00ff88"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- PlayerRendererView directly — fixes the FrameLayout cast error -->
    <com.albionplayersradar.ui.PlayerRendererView
        android:id="@+id/radar_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1a1a2e" />

    <TextView
        android:id="@+id/count_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Players: 0"
        android:textColor="#00ff88"
        android:textSize="12sp"
        android:padding="6dp"
        android:background="#1a1a1a" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#0a0a15">

        <TextView
            android:id="@+id/log_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#aaaaaa"
            android:textSize="11sp"
            android:padding="8dp"
            android:fontFamily="monospace" />
    </ScrollView>

</LinearLayout>
